---
import BaseLayout from "../../layouts/BaseLayout.astro";

const { sessionId } = Astro.params;
---

<BaseLayout title="Subway Elevator Sessions | Wallking">
    <div id="app-root" data-session-id={sessionId}></div>
</BaseLayout>

<script>
    import { createApp } from "vue";
    import SubwayGallery from "../../components/SubwayGallery.vue";

    const root = document.getElementById("app-root");
    if (root) {
        const sessionId = root.dataset.sessionId;
        const app = createApp(SubwayGallery, { sessionId });
        app.mount(root);
    }
</script>
