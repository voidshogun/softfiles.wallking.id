---
import BaseLayout from "../../layouts/BaseLayout.astro";

const { sessionId } = Astro.params;
---

<BaseLayout title="Bakery Sessions | Wallking">
    <div id="app-root" data-session-id={sessionId}></div>
</BaseLayout>

<script>
    import { createApp } from "vue";
    import BakeryGallery from "../../components/BakeryGallery.vue";

    const root = document.getElementById("app-root");
    if (root) {
        const sessionId = root.dataset.sessionId;
        const app = createApp(BakeryGallery, { sessionId });
        app.mount(root);
    }
</script>
